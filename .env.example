# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gestione_appuntamenti

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=nicovillano@libero.it
EMAIL_FROM_NAME=Nico Villano - Consulenza Fiscale

# Alternative: Gmail for better deliverability (free option)
# EMAIL_FROM=nicovillano.consulenza@gmail.com
# EMAIL_FROM_NAME=Nico Villano - Consulenza Fiscale

# Email Deliverability (Optional - for custom domain)
CUSTOM_DOMAIN=false
CUSTOM_EMAIL_FROM=info@yourdomain.it
DOMAIN_AUTHENTICATED=false

# Email Monitoring
TRACK_EMAIL_DELIVERABILITY=true
LOG_EMAIL_DETAILS=true

# Upload Service (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App Settings
JWT_SECRET=your_jwt_secret_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# URLs (per Render gratuito)
FRONTEND_URL=https://gestione-appuntamenti.onrender.com
ADMIN_URL=https://admin-gestione-appuntamenti.onrender.com
API_URL=https://api-gestione-appuntamenti.onrender.com
